---
/*
 * Rugix Admin docs. The only version for now is `next`, mounted at
 * `/docs/admin/<slug>`.
 */
import { getCollection, render } from "astro:content";
import { DocsLayout, titleize } from "@silitics/astro-docs";
import SiteFooter from "../../../layouts/SiteFooter.astro";
import {
  brand,
  nav,
  headerActions,
  getAdminDocsConfig,
} from "../../../site.ts";

export async function getStaticPaths() {
  const entries = await getCollection("docs-admin");
  return entries
    .filter((entry) => !entry.data.draft)
    .filter((entry) => entry.id === "next" || entry.id.startsWith("next/"))
    .map((entry) => {
      const slug = entry.id === "next" ? "" : entry.id.slice("next/".length);
      return {
        params: { slug: slug || undefined },
        props: { entry, pageSlug: slug || "introduction" },
      };
    });
}

const VERSION = "next";
const { entry, pageSlug } = Astro.props;
const docsConfig = await getAdminDocsConfig();
const { Content, headings } = await render(entry);
const explicitTitle = entry.data.title;
const title =
  explicitTitle ??
  headings[0]?.text ??
  (pageSlug ? titleize(pageSlug.split("/").at(-1)!) : "Rugix Admin");
const editExt = entry.filePath?.endsWith(".mdx") ? "mdx" : "md";
const editBaseUrl = docsConfig.versions.find(
  (v) => v.slug === VERSION,
)?.editBaseUrl;
const editUrl = `${editBaseUrl}/index.${editExt}`;
---

<DocsLayout
  brand={brand}
  nav={nav}
  actions={headerActions}
  config={docsConfig}
  versionSlug={VERSION}
  pageSlug={pageSlug}
  title={title}
  description={entry.data.description}
  headings={headings}
  basePath="/docs/admin/"
  bodyTitle={!!explicitTitle}
  editUrl={entry.id === VERSION ? editUrl : undefined}
  editExt={editExt}
>
  <Content />
  <SiteFooter slot="footer" />
</DocsLayout>
