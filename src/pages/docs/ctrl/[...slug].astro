---
/*
 * Rugix Ctrl default-version docs (1.2) at `/docs/ctrl/<slug>`.
 */
import { getCollection, render } from "astro:content";
import { DocsLayout, titleize } from "@silitics/astro-docs";
import SiteFooter from "../../../layouts/SiteFooter.astro";
import {
  brand,
  nav,
  headerActions,
  getCtrlDocsConfig,
} from "../../../site.ts";

export async function getStaticPaths() {
  const entries = await getCollection("docs-ctrl");
  const paths = entries
    .filter((entry) => !entry.data.draft)
    .filter((entry) => entry.id === "1.2" || entry.id.startsWith("1.2/"))
    .filter((entry) => entry.id !== "1.2/introduction")
    .map((entry) => {
      const slug = entry.id === "1.2" ? "" : entry.id.slice("1.2/".length);
      return {
        params: { slug: slug || undefined },
        props: { entry, pageSlug: slug },
      };
    });
  const introduction = entries.find((entry) => entry.id === "1.2/introduction");
  if (introduction !== undefined && !introduction.data.draft) {
    paths.push({
      params: { slug: undefined },
      props: { entry: introduction, pageSlug: "introduction" },
    });
  }
  return paths;
}

const DEFAULT_VERSION = "1.2";
const { entry, pageSlug } = Astro.props;
const docsConfig = await getCtrlDocsConfig();
const { Content, headings } = await render(entry);
const explicitTitle = entry.data.title;
const title =
  explicitTitle ??
  headings[0]?.text ??
  (pageSlug ? titleize(pageSlug.split("/").at(-1)!) : "Rugix Ctrl");
const editExt = entry.filePath?.endsWith(".mdx") ? "mdx" : "md";
---

<DocsLayout
  brand={brand}
  nav={nav}
  actions={headerActions}
  config={docsConfig}
  versionSlug={DEFAULT_VERSION}
  pageSlug={pageSlug}
  title={title}
  description={entry.data.description}
  headings={headings}
  basePath="/docs/ctrl/"
  bodyTitle={!!explicitTitle}
  editExt={editExt}
>
  <Content />
  <SiteFooter slot="footer" />
</DocsLayout>
