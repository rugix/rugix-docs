---
import {
  BaseLayout,
  Section,
  Button,
  Link,
  FaIcon,
} from "@silitics/astro-theme";
import SiteFooter from "../layouts/SiteFooter.astro";
import { faRocket, faArrowRight } from "@fortawesome/free-solid-svg-icons";
import {
  brand,
  nav,
  headerActions,
} from "../site.ts";

/*
 * Partner logos. The `mono: true` flag marks logos that are pure
 * white-on-transparent and should be inverted under the light theme so
 * they remain readable. Colored / multi-tone logos pass `mono: false`
 * and stay as-is in both themes.
 */
const partners = [
  {
    href: "https://umbrel.com/",
    src: "/img/third-party-logos/umbrel.svg",
    alt: "Umbrel, Inc.",
    mono: true,
  },
  {
    href: "https://goaqa.com/",
    src: "/img/third-party-logos/aqa.png",
    alt: "Aqa Technologies, Inc.",
    mono: true,
  },
  {
    href: "https://www.ebike-checker.de/en/",
    src: "/img/third-party-logos/echecker.svg",
    alt: "eChecker",
    mono: true,
  },
  {
    href: "https://enmo.ai/",
    src: "/img/third-party-logos/enmo.webp",
    alt: "Enmo",
    mono: true,
  },
];

const stories = [
  {
    img: "/img/umbrel-pro.jpg",
    alt: "Umbrel Pro device",
    name: "Umbrel",
    body: `<a href="https://umbrel.com/">Umbrel</a> is a personal home cloud platform that lets anyone self-host their files, media, and applications with tens of thousands of installations worldwide. Umbrel chose Rugix for <a href="https://umbrel.com/umbrelos">umbrelOS</a>, powering devices like the recently launched <a href="https://umbrel.com/umbrel-pro">Umbrel Pro</a>, their premium home cloud server. Rugix was chosen for its robustness, builtin state management with clean factory resets, and highly efficient delta updates.`,
  },
  {
    img: "/img/echecker-testbench.jpg",
    alt: "eChecker test bench with e-bike",
    name: "eChecker",
    body: `<a href="https://www.ebike-checker.de/en/">eChecker</a> builds test benches for e-bikes, drive units, and e-scooters used by test institutes and manufacturers worldwide. Each test bench is controlled by an embedded Linux system, powered by and updated through Rugix. Rugix enabled eChecker to easily build custom system images and reliably deliver over-the-air software updates to test benches deployed across customer sites.`,
  },
  {
    img: "/img/enmo-battery-brain.webp",
    alt: "BatteryBrain device",
    name: "BatteryBrain",
    body: `"At Enmo, we use Rugix for our product, BatteryBrain — a device optimizing battery systems based on spot prices, battery health, production inputs, and electricity markets. Rugix has been essential in bringing BatteryBrain to a production-ready state as quickly and efficiently as possible. It has simplified the creation of a custom Raspberry Pi image and enabled seamless over-the-air (OTA) updates."`,
    quote: "David Lekve, CTO at enmo",
  },
];

const tools = [
  {
    href: "/docs/ctrl",
    title: "Rugix Ctrl",
    blurb: "On-device update engine.",
    body: "Atomic A/B system updates with automatic rollback, delta updates, cryptographic verification, and robust state management. Integrates with different fleet management solutions. Optionally, deploy and manage application workloads with Rugix Apps.",
  },
  {
    href: "/docs/bakery",
    title: "Rugix Bakery",
    blurb: "Custom Linux build system.",
    body: "Build custom Linux distributions in days, not months. Based on Debian or Alpine Linux. Container-based reproducible builds, multiple system variants, integrated testing with VM support, and SBOM generation. OTA updates powered by Rugix Ctrl.",
  },
];
---

<BaseLayout
  title="Over-the-Air Updates for Embedded Linux"
  description="Deploy updates with confidence. Never brick a device. 100% open-source, atomic updates, delta compression, cryptographic verification."
  brand={brand}
  nav={nav}
  actions={headerActions}
>
  <Section background="hero" padding="hero">
    <div slot="decoration" class="bg-grid-fade absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl text-center">
      <h1
        class="font-display text-balance text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl"
      >
        Over-the-Air Updates for{" "}
        <span class="text-gradient">Embedded Linux</span>
      </h1>
      <p
        class="text-content mx-auto mt-6 max-w-2xl text-lg leading-relaxed md:text-xl"
      >
        <strong>Deploy updates with confidence. Never brick a device.</strong>
      </p>
      <p class="text-content-muted mx-auto mt-3 max-w-2xl text-base md:text-lg">
        100% open-source. Atomic updates. Delta compression. Cryptographic
        verification.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <Button href="/docs/latest/getting-started">
          <FaIcon icon={faRocket} />
          From Zero to OTA Update in 30 Minutes
        </Button>
        <Button variant="secondary" href="/blog">
          Read the blog
        </Button>
      </div>
    </div>
  </Section>

  <Section background="none" padding="default" class="!pt-8 md:!pt-12">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl font-bold md:text-4xl">
        Two Tools. One Goal.
      </h2>
      <p class="text-content-muted mt-4 text-lg">
        Robust and secure updates without the complexity.
      </p>
    </div>
    <div class="mx-auto mt-12 grid max-w-5xl gap-6 md:grid-cols-2">
      {
        tools.map((tool) => (
          <a
            href={tool.href}
            class="card group flex flex-col gap-3 p-6 no-underline"
          >
            <h3 class="font-display text-xl font-semibold">{tool.title}</h3>
            <p class="text-content text-sm font-semibold">{tool.blurb}</p>
            <p class="text-content-muted text-sm leading-relaxed">{tool.body}</p>
            <span class="text-primary inline-flex items-center gap-2 text-sm font-medium">
              Learn more <FaIcon icon={faArrowRight} class="text-xs" />
            </span>
          </a>
        ))
      }
    </div>
    <p class="text-content-muted mx-auto mt-10 max-w-2xl text-center text-sm leading-relaxed">
      Rugix Ctrl runs on your device and installs updates. Rugix Bakery builds
      the system images. Use both together for a complete solution, or
      integrate Rugix Ctrl into your existing Yocto or Buildroot workflow.
    </p>
  </Section>

  <Section background="section" padding="default">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-display text-3xl font-bold md:text-4xl">Trusted By</h2>
    </div>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
      {
        partners.map((p) => (
          <a
            href={p.href}
            target="_blank"
            rel="noopener"
            class={p.mono ? "logo-mono" : ""}
            aria-label={p.alt}
          >
            <img src={p.src} alt={p.alt} class="max-h-7" />
          </a>
        ))
      }
      <span class="text-content-subtle text-sm tracking-wider uppercase">
        and many more
      </span>
    </div>

    <style is:global>
      /*
       * Many partner logos are shipped as monochrome white-on-transparent
       * SVGs. `brightness(0)` paints every non-transparent pixel black
       * while leaving transparency intact, which is exactly what a
       * white-on-light surface needs. Colored logos (PNG / WebP) skip
       * the filter via the `mono: false` flag.
       *
       * The `!important` overrides Tailwind v4's default `filter:` chain
       * (a list of `var(--tw-*)` fallbacks Tailwind injects on every
       * filter consumer); without it our rule loses to Tailwind's reset.
       */
      [data-theme="light"] .logo-mono img {
        filter: brightness(0) opacity(0.7) !important;
      }
      @media (prefers-color-scheme: light) {
        :root:not([data-theme="dark"]) .logo-mono img {
          filter: brightness(0) opacity(0.7) !important;
        }
      }
    </style>
    <div class="mx-auto mt-12 grid max-w-5xl gap-6 md:grid-cols-3">
      <blockquote class="card flex flex-col gap-4 p-6 italic">
        <p class="text-content leading-relaxed">
          "When you ship OTA updates to tens of thousands of devices in
          people's homes, you need rock-solid reliability. Rugix delivers
          exactly that."
        </p>
        <footer class="text-content-muted text-sm not-italic">
          Luke Childs, CTO at <Link href="https://umbrel.com/" external>Umbrel</Link>
        </footer>
      </blockquote>
      <blockquote class="card flex flex-col gap-4 p-6 italic">
        <p class="text-content leading-relaxed">
          "If you're not using Rugix, you're making things harder than they
          need to be."
        </p>
        <footer class="text-content-muted text-sm not-italic">
          David Lekve, CTO at <Link href="https://enmo.ai" external>enmo</Link>
        </footer>
      </blockquote>
      <blockquote class="card flex flex-col gap-4 p-6 italic">
        <p class="text-content leading-relaxed">
          "Rugix is thoughtfully designed, fast to get started with, and
          flexible in all the right ways. It's the tool suite for embedded
          Linux I've always wanted."
        </p>
        <footer class="text-content-muted text-sm not-italic">
          Rameen Aryanpur, CEO at <Link href="https://goaqa.com/" external>Aqa</Link>
        </footer>
      </blockquote>
    </div>
  </Section>

  <Section background="none" padding="default">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-display text-3xl font-bold md:text-4xl">Success Stories</h2>
    </div>
    <div class="mx-auto mt-12 grid max-w-6xl gap-12 md:grid-cols-2 lg:grid-cols-3">
      {
        stories.map((s) => (
          <div>
            <img
              src={s.img}
              alt={s.alt}
              class="border-divider aspect-video w-full rounded-xl border object-cover"
              loading="lazy"
            />
            <h3 class="font-display mt-4 text-xl font-semibold">{s.name}</h3>
            <p class="text-content-muted mt-2 text-sm leading-relaxed" set:html={s.body} />
            {s.quote && <p class="text-content-subtle mt-2 text-xs">{s.quote}</p>}
          </div>
        ))
      }
    </div>
  </Section>

  <Section background="cta" padding="default">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl font-bold md:text-4xl">
        Ship updates without fear.
      </h2>
      <p class="text-content-muted mt-4 text-lg">
        Drop Rugix into your project today. The first OTA update is 30 minutes
        away.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/docs/latest/getting-started">
          Get started
          <FaIcon icon={faArrowRight} />
        </Button>
        <Button variant="secondary" href="/commercial-support">
          Commercial support
        </Button>
      </div>
    </div>
  </Section>

  <SiteFooter slot="footer" />
</BaseLayout>
