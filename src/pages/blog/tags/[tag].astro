---
import { getCollection } from "astro:content";
import { marked } from "marked";
import {
  BaseLayout,
  Section,
  Badge,
  FaIcon,
} from "@silitics/astro-theme";
import { faArrowRight } from "@fortawesome/free-solid-svg-icons";
import SiteFooter from "../../../layouts/SiteFooter.astro";
import BlogSidebar from "../../../components/BlogSidebar.astro";
import { brand, nav, headerActions } from "../../../site.ts";
import {
  dateFromId,
  slugFromEntry,
  tagHref,
  tagSlug,
  teaserFor,
} from "../../../lib/blog.ts";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tags = new Map<string, { label: string; posts: typeof posts }>();

  for (const post of posts.filter((p) => !p.data.draft)) {
    for (const tag of post.data.tags ?? []) {
      const slug = tagSlug(tag);
      const group = tags.get(slug);
      if (group) {
        group.posts.push(post);
      } else {
        tags.set(slug, { label: tag, posts: [post] });
      }
    }
  }

  return Array.from(tags, ([slug, group]) => ({
    params: { tag: slug },
    props: group,
  }));
}

const { label, posts } = Astro.props;
const sorted = posts
  .map((p) => {
    const teaser = teaserFor(p);
    return {
      post: p,
      date: p.data.date ?? dateFromId(p.id),
      teaserHtml: teaser ? marked.parse(teaser, { async: false }) : null,
    };
  })
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout
  title={`Posts tagged ${label}`}
  description={`Blog posts tagged ${label}.`}
  brand={brand}
  nav={nav}
  actions={headerActions}
>
  <Section background="hero" padding="compact">
    <div slot="decoration" class="bg-grid-fade absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl text-center">
      <p class="text-content-subtle font-mono text-sm tracking-wider uppercase">
        Blog tag
      </p>
      <h1 class="font-display mt-3 text-4xl font-bold md:text-5xl">{label}</h1>
      <p class="text-content-muted mt-4 text-lg">
        Posts tagged with {label}.
      </p>
    </div>
  </Section>

  <div class="mx-auto flex w-full max-w-7xl flex-col gap-10 px-4 pt-8 pb-16 md:pb-24 lg:flex-row lg:px-6">
    <aside class="lg:sticky lg:top-20 lg:max-h-[calc(100dvh-6rem)] lg:w-60 lg:shrink-0 lg:self-start lg:overflow-y-auto">
      <BlogSidebar currentSlug="" />
    </aside>
    <ul class="flex max-w-3xl flex-1 flex-col gap-6">
      {
        sorted.map(({ post, date, teaserHtml }) => {
          const href = `/blog/${slugFromEntry(post)}`;
          const tags = post.data.tags ?? [];
          return (
            <li>
              <article class="card group relative p-6">
                <div class="text-content-subtle font-mono text-xs tracking-wider uppercase">
                  <time datetime={date.toISOString()}>
                    {date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>
                <h2 class="font-display mt-2 text-2xl font-semibold">
                  <a
                    href={href}
                    class="text-content group-hover:text-primary stretched-link transition-colors no-underline"
                  >
                    {post.data.title}
                  </a>
                </h2>
                {teaserHtml && (
                  <div
                    class="blog-teaser text-content-muted mt-2 text-sm leading-relaxed"
                    set:html={teaserHtml}
                  />
                )}
                {tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {tags.map((tag: string) => (
                      <a href={tagHref(tag)} class="relative z-[2] no-underline">
                        <Badge variant={tagSlug(tag) === tagSlug(label) ? "primary" : "default"}>
                          {tag}
                        </Badge>
                      </a>
                    ))}
                  </div>
                )}
                <span class="text-primary mt-4 inline-flex items-center gap-2 text-sm font-medium">
                  Read post <FaIcon icon={faArrowRight} class="text-xs" />
                </span>
              </article>
            </li>
          );
        })
      }
    </ul>
  </div>

  <SiteFooter slot="footer" />
</BaseLayout>

<style is:global>
  .stretched-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }
  .blog-teaser a,
  .blog-teaser a:hover {
    position: relative;
    z-index: 2;
  }
  .blog-teaser {
    color: inherit;
    line-height: 1.6;
  }
  .blog-teaser p {
    margin: 0 0 0.5rem;
  }
  .blog-teaser p:last-child {
    margin-bottom: 0;
  }
  .blog-teaser a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-teaser strong {
    color: var(--theme-content);
    font-weight: 600;
  }
  .blog-teaser em {
    font-style: italic;
  }
  .blog-teaser code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: transparent;
    border: 0;
    padding: 0;
  }
  .blog-teaser pre,
  .blog-teaser blockquote,
  .blog-teaser table,
  .blog-teaser hr,
  .blog-teaser h1,
  .blog-teaser h2,
  .blog-teaser h3,
  .blog-teaser h4,
  .blog-teaser h5,
  .blog-teaser h6,
  .blog-teaser ul,
  .blog-teaser ol {
    display: none;
  }
</style>
